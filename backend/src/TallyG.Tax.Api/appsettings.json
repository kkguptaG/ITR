{
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft.AspNetCore": "Warning",
        "Microsoft.EntityFrameworkCore": "Warning"
      }
    }
  },
  "Database": {
    "Provider": "Postgres"
  },
  "ConnectionStrings": {
    "Default": "Host=localhost;Port=5432;Database=tallyg_tax;Username=postgres;Password=postgres"
  },
  "Auth": {
    "Jwt": {
      "Issuer": "tallyg.tax",
      "Audience": "tallyg.tax.clients",
      "AccessTokenMinutes": 15,
      "RefreshTokenDays": 30,
      "SigningKey": "tallyg-dev-signing-key-please-override-in-config-0123456789"
    },
    "OtpHashKey": "tallyg-dev-otp-hmac-key-change-me",
    "OtpTtlSeconds": 300
  },
  "Payments": {
    "Razorpay": {
      "KeyId": "rzp_test_stub0000000000",
      "KeySecret": "razorpay_dev_secret_change_me"
    }
  },
  "Storage": {
    "LocalRoot": "D:/TallyGTax/backend/.localstore",
    "PublicBaseUrl": "http://localhost:5080/api/v1"
  },
  "Cors": {
    "Origins": [ "http://localhost:3000" ]
  },
  "AllowedHosts": "*"
}
