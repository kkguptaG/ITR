# =============================================================================
# TallyG Tax Portal — repo-wide ignores
# (backend/ and frontend/ may add their own scoped .gitignore on top.)
# =============================================================================

# ---- .NET build output -------------------------------------------------------
bin/
obj/
*.user

# ---- Node / Next.js ----------------------------------------------------------
node_modules/
.next/
out/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# ---- Local dev artifacts -----------------------------------------------------
.localstore/
*.db
*.db-shm
*.db-wal

# ---- Secrets / environment ---------------------------------------------------
.env
.env.*
!.env.example

# ---- Editors / OS ------------------------------------------------------------
.vs/
.vscode/
.idea/
.DS_Store
Thumbs.db
