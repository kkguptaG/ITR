# Base URL of the TallyG Tax backend API (foundation runs ASP.NET Core on :5080).
NEXT_PUBLIC_API_URL=http://localhost:5080/api/v1

# STUB (demo only): the dev gateway key secret used to SIMULATE the Razorpay /
# Cashfree checkout widget client-side. A real PSP returns the signature from its
# hosted widget; with no PSP account the mock checkout recomputes the same
# HMAC-SHA256("orderId|paymentId") the backend RazorpayStub verifies. Must match
# backend appsettings Payments:Razorpay:KeySecret. Never set a real secret here.
NEXT_PUBLIC_PAYMENTS_DEV_SECRET=razorpay_dev_secret_change_me
