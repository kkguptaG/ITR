# =============================================================================
# TallyG Tax Portal — environment template for the Docker stack.
#
# Copy to `infra/.env` (sits next to docker-compose.yml; auto-loaded by Compose)
# and adjust as needed. The defaults below match backend/appsettings.json so the
# stack runs with no edits. DO NOT commit a real .env — see root .gitignore.
# =============================================================================

# ---- PostgreSQL (db service) -------------------------------------------------
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=tallyg_tax

# ---- API (api service) -------------------------------------------------------
# Development => Swagger UI enabled + OTP code returned in the response (devOtp).
ASPNETCORE_ENVIRONMENT=Development
# EF Core provider switch: Postgres (Docker) or Sqlite (no-infra dev).
DATABASE__PROVIDER=Postgres
# Connection string the API reads from ConnectionStrings:Default.
# "db" is the compose service name on the internal network.
CONNECTIONSTRINGS__DEFAULT=Host=db;Port=5432;Database=tallyg_tax;Username=postgres;Password=postgres

# JWT signing + OTP HMAC keys (override these for anything beyond local demo).
AUTH__JWT__SIGNINGKEY=tallyg-dev-signing-key-please-override-in-config-0123456789
AUTH__OTPHASHKEY=tallyg-dev-otp-hmac-key-change-me

# Razorpay (stubbed — no real account needed for the demo).
PAYMENTS__RAZORPAY__KEYID=rzp_test_stub0000000000
PAYMENTS__RAZORPAY__KEYSECRET=razorpay_dev_secret_change_me

# Local document store inside the api container (Linux path; volume-backed).
STORAGE__LOCALROOT=/app/.localstore
STORAGE__PUBLICBASEURL=http://localhost:5080/api/v1

# ---- Web (web service) -------------------------------------------------------
# Browser-facing API base URL. Must be reachable from your machine, so localhost
# (not the internal "api" service name). Baked into the client bundle at build.
NEXT_PUBLIC_API_URL=http://localhost:5080/api/v1
